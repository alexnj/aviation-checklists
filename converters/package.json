{
  "name": "efis-converter",
  "version": "1.0.0",
  "description": "Converts checklist source files to different EFIS formats",
  "main": "convert.js",
  "scripts": {
    "build": "tsc *.ts --module commonjs --esModuleInterop --target es2022 --lib es2022,dom --skipLibCheck",
    "convert": "node convert.js"
  },
  "devDependencies": {
    "typescript": "~5.9.2"
  }
}
